{
  "name": "vochat",
  "version": "1.0.0",
  "description": "Chat vocal & texte avec tes amis",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build-all": "electron-builder --win --mac --linux"
  },
  "build": {
    "appId": "com.vochat.app",
    "productName": "VoChat",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icon.png",
      "createDesktopShortcut": true,
      "shortcutName": "VoChat"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**",
      "icon.png"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
